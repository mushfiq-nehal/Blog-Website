<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-grow">
    <div class="max-w-7xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center mb-8">
            <h1 class="text-4xl font-bold text-gray-900">Latest Posts</h1>
            <% if (user) { %>
            <a href="/posts/create/new" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-semibold">
                Create New Post
            </a>
            <% } %>
        </div>

        <% if (posts.length === 0) { %>
        <div class="bg-white rounded-lg shadow-md p-8 text-center">
            <p class="text-gray-500 text-lg">No posts available yet.</p>
            <% if (user) { %>
            <a href="/posts/create/new" class="mt-4 inline-block text-indigo-600 hover:text-indigo-800 font-semibold">
                Create your first post
            </a>
            <% } %>
        </div>
        <% } else { %>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
            <% posts.forEach(post => { %>
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300">
                <div class="p-6">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-sm text-gray-500">
                            <%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                        </span>
                        <% if (post.visibility === 'private') { %>
                        <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">Private</span>
                        <% } %>
                    </div>

                    <h2 class="text-2xl font-bold text-gray-900 mb-2 hover:text-indigo-600">
                        <a href="/posts/<%= post.slug %>"><%= post.title %></a>
                    </h2>

                    <p class="text-gray-600 mb-4 line-clamp-3">
                        <%= post.excerpt %>
                    </p>

                    <div class="flex items-center justify-between">
                        <span class="text-sm text-gray-500">
                            By <span class="font-semibold"><%= post.author_name %></span>
                        </span>
                        <a href="/posts/<%= post.slug %>" class="text-indigo-600 hover:text-indigo-800 font-semibold text-sm">
                            Read More →
                        </a>
                    </div>
                </div>
            </article>
            <% }) %>
        </div>
        <% } %>
    </div>
</main>

<%- include('../partials/footer') %>
