<%- include('../partials/head') %>
<%- include('../partials/header') %>

<main class="flex-grow">
    <article class="max-w-4xl mx-auto py-10 px-4 sm:px-6 lg:px-8">
        <!-- Post Header -->
        <div class="bg-white rounded-lg shadow-md p-8 mb-6">
            <div class="mb-4">
                <div class="flex items-center justify-between text-sm text-gray-500 mb-2">
                    <span><%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
                    <% if (post.visibility === 'private') { %>
                    <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded">Private</span>
                    <% } %>
                </div>
                <h1 class="text-4xl font-bold text-gray-900 mb-4"><%= post.title %></h1>
                <p class="text-gray-600">
                    By <span class="font-semibold text-indigo-600"><%= post.author_name %></span>
                </p>
            </div>

            <!-- Post Actions (if author or admin) -->
            <% if (user && (user.id === post.author_id || user.role === 'admin')) { %>
            <div class="flex space-x-2 mb-4 pb-4 border-b">
                <a href="/posts/<%= post.slug %>/edit" class="bg-blue-500 hover:bg-blue-600 text-white px-4 py-2 rounded text-sm">
                    Edit Post
                </a>
                <form action="/posts/<%= post.slug %>/delete" method="POST" onsubmit="return confirm('Are you sure you want to delete this post?');" class="inline">
                    <button type="submit" class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded text-sm">
                        Delete Post
                    </button>
                </form>
            </div>
            <% } %>

            <!-- Post Content -->
            <div class="prose prose-lg max-w-none prose-content">
                <%- post.content %>
            </div>

            <!-- Social Share Buttons -->
            <div class="mt-8 pt-6 border-t">
                <h3 class="text-lg font-semibold mb-4">Share this post:</h3>
                <div class="flex space-x-4">
                    <a href="<%= shareUrls.facebook %>" target="_blank" rel="noopener noreferrer"
                       class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded flex items-center space-x-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                        <span>Facebook</span>
                    </a>
                    <a href="<%= shareUrls.x %>" target="_blank" rel="noopener noreferrer"
                       class="bg-black hover:bg-gray-800 text-white px-4 py-2 rounded flex items-center space-x-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/>
                        </svg>
                        <span>X</span>
                    </a>
                    <a href="<%= shareUrls.linkedin %>" target="_blank" rel="noopener noreferrer"
                       class="bg-blue-700 hover:bg-blue-800 text-white px-4 py-2 rounded flex items-center space-x-2">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        <span>LinkedIn</span>
                    </a>
                </div>
            </div>
        </div>

        <!-- Comments Section -->
        <div id="comments" class="bg-white rounded-lg shadow-md p-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Comments (<%= comments.length %>)</h2>

            <!-- Comment Form -->
            <% if (user) { %>
            <div class="mb-8">
                <form action="/comments/create" method="POST">
                    <input type="hidden" name="postId" value="<%= post.id %>">
                    <textarea
                        name="content"
                        rows="3"
                        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                        placeholder="Write a comment..."
                        required
                    ></textarea>
                    <button type="submit" class="mt-2 bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg">
                        Post Comment
                    </button>
                </form>
            </div>
            <% } else { %>
            <div class="mb-8 p-4 bg-gray-100 rounded-lg text-center">
                <p class="text-gray-600">
                    <a href="/auth/login" class="text-indigo-600 hover:text-indigo-800 font-semibold">Login</a>
                    to comment on this post.
                </p>
            </div>
            <% } %>

            <!-- Comments List -->
            <div class="space-y-6">
                <% if (comments.length === 0) { %>
                <p class="text-gray-500 text-center">No comments yet. Be the first to comment!</p>
                <% } else { %>
                    <% function renderComment(comment, depth = 0) { %>
                    <div class="<%= depth > 0 ? 'ml-8 border-l-2 border-gray-200 pl-4' : '' %>">
                        <div class="bg-gray-50 rounded-lg p-4">
                            <div class="flex justify-between items-start mb-2">
                                <div>
                                    <span class="font-semibold text-gray-900"><%= comment.username %></span>
                                    <span class="text-sm text-gray-500 ml-2">
                                        <%= new Date(comment.created_at).toLocaleDateString() %>
                                    </span>
                                </div>
                                <% if (user && (user.id === comment.user_id || user.role === 'admin')) { %>
                                <form action="/comments/<%= comment.id %>/delete" method="POST" onsubmit="return confirm('Delete this comment?');">
                                    <button type="submit" class="text-red-500 hover:text-red-700 text-sm">Delete</button>
                                </form>
                                <% } %>
                            </div>
                            <p class="text-gray-700"><%= comment.content %></p>

                            <% if (user) { %>
                            <button onclick="toggleReplyForm('<%= comment.id %>')" class="mt-2 text-indigo-600 hover:text-indigo-800 text-sm font-semibold">
                                Reply
                            </button>
                            <div id="reply-form-<%= comment.id %>" class="hidden mt-4">
                                <form action="/comments/create" method="POST">
                                    <input type="hidden" name="postId" value="<%= post.id %>">
                                    <input type="hidden" name="parentId" value="<%= comment.id %>">
                                    <textarea
                                        name="content"
                                        rows="2"
                                        class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                        placeholder="Write a reply..."
                                        required
                                    ></textarea>
                                    <div class="flex space-x-2 mt-2">
                                        <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded text-sm">
                                            Post Reply
                                        </button>
                                        <button type="button" onclick="toggleReplyForm('<%= comment.id %>')" class="bg-gray-300 hover:bg-gray-400 text-gray-700 px-4 py-2 rounded text-sm">
                                            Cancel
                                        </button>
                                    </div>
                                </form>
                            </div>
                            <% } %>
                        </div>

                        <!-- Nested Replies -->
                        <% if (comment.replies && comment.replies.length > 0) { %>
                            <div class="mt-4">
                                <% comment.replies.forEach(reply => { %>
                                    <%- renderComment(reply, depth + 1) %>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                    <% } %>

                    <% comments.forEach(comment => { %>
                        <%- renderComment(comment) %>
                    <% }) %>
                <% } %>
            </div>
        </div>
    </article>
</main>

<script>
function toggleReplyForm(commentId) {
    const form = document.getElementById(`reply-form-${commentId}`);
    form.classList.toggle('hidden');
}
</script>

<%- include('../partials/footer') %>
